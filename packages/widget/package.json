{
  "name": "@chatcops/widget",
  "version": "0.1.0",
  "description": "Embeddable AI chatbot widget - zero dependencies, Shadow DOM isolated",
  "type": "module",
  "main": "dist/chatcops.min.js",
  "module": "dist/chatcops.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/chatcops.esm.js",
      "require": "./dist/chatcops.min.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "terser": "^5.37.0",
    "vitest": "^3.0.0",
    "happy-dom": "^16.0.0"
  },
  "license": "MIT"
}
