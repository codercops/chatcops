---
---
<section class="relative py-28">
  <div class="section-divider"></div>

  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center mb-16" data-animate>
      <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary-glow px-3 py-1 text-xs font-medium text-primary-light mb-5">
        <svg viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/></svg>
        Features
      </span>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        Everything you <span class="text-gradient">need</span>
      </h2>
      <p class="mt-4 text-text-secondary max-w-lg mx-auto text-lg">
        Production-ready from day one. Multi-provider AI, lead capture, analytics, and more.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Multi-Provider -->
      <div class="rounded-2xl border border-border bg-bg-card p-6 transition-colors hover:border-border-hover" data-animate data-animate-delay="1">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-primary-glow">
          <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-primary-light">
            <path d="M13 7H7v6h6V7z" />
            <path fill-rule="evenodd" d="M7 2a1 1 0 012 0v1h2V2a1 1 0 112 0v1h2a2 2 0 012 2v2h1a1 1 0 110 2h-1v2h1a1 1 0 110 2h-1v2a2 2 0 01-2 2h-2v1a1 1 0 11-2 0v-1H9v1a1 1 0 11-2 0v-1H5a2 2 0 01-2-2v-2H2a1 1 0 110-2h1V9H2a1 1 0 010-2h1V5a2 2 0 012-2h2V2zM5 5h10v10H5V5z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="mb-1.5 text-[15px] font-semibold text-text">Multi-Provider</h3>
        <p class="text-sm leading-relaxed text-text-secondary">Claude, OpenAI, and Gemini. Switch providers with a single config change.</p>
      </div>

      <!-- Zero Dependencies -->
      <div class="rounded-2xl border border-border bg-bg-card p-6 transition-colors hover:border-border-hover" data-animate data-animate-delay="2">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl" style="background: rgba(34,211,238,0.1);">
          <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-cyan-400">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="mb-1.5 text-[15px] font-semibold text-text">Zero Dependencies</h3>
        <p class="text-sm leading-relaxed text-text-secondary">Shadow DOM isolated widget. ~7KB gzipped. No framework lock-in.</p>
      </div>

      <!-- Streaming -->
      <div class="rounded-2xl border border-border bg-bg-card p-6 transition-colors hover:border-border-hover" data-animate data-animate-delay="3">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl" style="background: rgba(34,197,94,0.1);">
          <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-emerald-400">
            <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="mb-1.5 text-[15px] font-semibold text-text">Streaming</h3>
        <p class="text-sm leading-relaxed text-text-secondary">Real-time SSE streaming from all providers. Token-by-token responses.</p>
      </div>

      <!-- Lead Capture -->
      <div class="rounded-2xl border border-border bg-bg-card p-6 transition-colors hover:border-border-hover" data-animate data-animate-delay="4">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl" style="background: rgba(245,158,11,0.1);">
          <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-amber-400">
            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
          </svg>
        </div>
        <h3 class="mb-1.5 text-[15px] font-semibold text-text">Lead Capture</h3>
        <p class="text-sm leading-relaxed text-text-secondary">Built-in tool for capturing contact info with webhook support.</p>
      </div>

      <!-- Knowledge Base -->
      <div class="rounded-2xl border border-border bg-bg-card p-6 transition-colors hover:border-border-hover" data-animate data-animate-delay="5">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl" style="background: rgba(244,114,182,0.1);">
          <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-pink-400">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z" />
          </svg>
        </div>
        <h3 class="mb-1.5 text-[15px] font-semibold text-text">Knowledge Base</h3>
        <p class="text-sm leading-relaxed text-text-secondary">Feed text chunks or FAQ pairs for context-aware, grounded responses.</p>
      </div>

      <!-- i18n -->
      <div class="rounded-2xl border border-border bg-bg-card p-6 transition-colors hover:border-border-hover" data-animate data-animate-delay="6">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl" style="background: rgba(129,140,248,0.1);">
          <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-indigo-400">
            <path fill-rule="evenodd" d="M7 2a1 1 0 011 1v1h3a1 1 0 110 2H9.578a18.87 18.87 0 01-1.724 4.78c.29.354.596.696.914 1.026a1 1 0 11-1.44 1.389 21.034 21.034 0 01-.554-.6 19.098 19.098 0 01-3.107 3.567 1 1 0 01-1.334-1.49 17.087 17.087 0 003.13-3.733 18.992 18.992 0 01-1.487-2.494 1 1 0 111.79-.89c.234.47.489.928.764 1.372.417-.934.752-1.913.997-2.927H3a1 1 0 110-2h3V3a1 1 0 011-1zm6 6a1 1 0 01.894.553l2.991 5.982a.869.869 0 01.02.037l.99 1.98a1 1 0 11-1.79.895L15.383 16h-4.764l-.724 1.447a1 1 0 11-1.788-.894l.99-1.98.019-.038 2.99-5.982A1 1 0 0113 8zm-1.382 6h2.764L13 11.236 11.618 14z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="mb-1.5 text-[15px] font-semibold text-text">i18n</h3>
        <p class="text-sm leading-relaxed text-text-secondary">8 built-in locales. Fully customizable strings for any language.</p>
      </div>

      <!-- Persistence -->
      <div class="rounded-2xl border border-border bg-bg-card p-6 transition-colors hover:border-border-hover" data-animate data-animate-delay="7">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl" style="background: rgba(56,189,248,0.1);">
          <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-sky-400">
            <path d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2h-1.528A6 6 0 004 9.528V4z" />
            <path fill-rule="evenodd" d="M8 10a4 4 0 00-3.446 6.032l-1.261 1.26a1 1 0 101.414 1.415l1.261-1.261A4 4 0 108 10zm-2 4a2 2 0 114 0 2 2 0 01-4 0z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="mb-1.5 text-[15px] font-semibold text-text">Persistence</h3>
        <p class="text-sm leading-relaxed text-text-secondary">localStorage on client, pluggable stores on server. Conversations survive refreshes.</p>
      </div>

      <!-- Deploy Anywhere -->
      <div class="rounded-2xl border border-border bg-bg-card p-6 transition-colors hover:border-border-hover" data-animate data-animate-delay="8">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl" style="background: rgba(168,85,247,0.1);">
          <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-purple-400">
            <path fill-rule="evenodd" d="M2 5a2 2 0 012-2h12a2 2 0 012 2v2a2 2 0 01-2 2H4a2 2 0 01-2-2V5zm14 1a1 1 0 11-2 0 1 1 0 012 0zM2 13a2 2 0 012-2h12a2 2 0 012 2v2a2 2 0 01-2 2H4a2 2 0 01-2-2v-2zm14 1a1 1 0 11-2 0 1 1 0 012 0z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="mb-1.5 text-[15px] font-semibold text-text">Deploy Anywhere</h3>
        <p class="text-sm leading-relaxed text-text-secondary">Express, Vercel, Cloudflare Workers. Ready-made adapters included.</p>
      </div>
    </div>
  </div>
</section>
