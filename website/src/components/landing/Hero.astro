---
---
<section class="relative min-h-screen overflow-hidden pt-32 pb-20">
  <!-- Dot grid background -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.04) 1px, transparent 0); background-size: 32px 32px; mask-image: radial-gradient(ellipse 70% 50% at 50% 30%, black, transparent 70%); -webkit-mask-image: radial-gradient(ellipse 70% 50% at 50% 30%, black, transparent 70%);"
  ></div>

  <!-- Subtle top glow -->
  <div class="pointer-events-none absolute -top-[200px] left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full opacity-30" style="background: radial-gradient(ellipse, rgba(99,102,241,0.15), transparent 70%);"></div>

  <div class="relative mx-auto max-w-4xl px-6">
    <!-- Badge -->
    <div class="flex justify-center mb-8" data-animate>
      <a
        href="https://github.com/codercops/chatcops"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-full border border-border bg-bg-surface px-4 py-1.5 text-xs text-text-secondary transition-colors hover:border-border-hover"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-success animate-pulse"></span>
        Open Source &mdash; MIT Licensed
        <svg viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3 opacity-40">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </a>
    </div>

    <!-- Heading -->
    <h1 class="text-center text-5xl font-bold leading-[1.08] tracking-tight sm:text-6xl lg:text-7xl" data-animate data-animate-delay="1">
      AI Chat Widget
      <br />
      for <span class="text-gradient">Any Website</span>
    </h1>

    <!-- Subtitle -->
    <p class="mx-auto mt-6 max-w-xl text-center text-lg leading-relaxed text-text-secondary" data-animate data-animate-delay="2">
      Drop-in AI chatbot that connects to Claude, OpenAI, or Gemini.
      <br class="hidden sm:block" />
      One script tag. Zero dependencies. Full control.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4" data-animate data-animate-delay="3">
      <a
        href="/getting-started/quick-start"
        class="inline-flex items-center gap-2 rounded-xl bg-primary px-7 py-3 text-sm font-medium text-white transition-all hover:bg-primary-dark active:scale-[0.98]"
      >
        Get Started
        <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </a>
      <a
        href="https://github.com/codercops/chatcops"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-xl border border-border px-7 py-3 text-sm font-medium text-text-secondary transition-colors hover:border-border-hover hover:text-text"
      >
        <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4">
          <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        Star on GitHub
        <span id="gh-stars" class="inline-flex items-center rounded-md bg-white/10 px-1.5 py-0.5 text-xs font-semibold tabular-nums" style="display:none;"></span>
      </a>
    </div>

    <!-- Code Block -->
    <div class="mx-auto mt-16 max-w-lg" data-animate data-animate-delay="4">
      <div class="rounded-2xl border border-border bg-bg-surface overflow-hidden">
        <!-- Window chrome -->
        <div class="flex items-center gap-2 px-4 py-3 border-b border-border">
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-[#ef4444]/60"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-[#f59e0b]/60"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-[#22c55e]/60"></div>
          </div>
          <span class="text-[11px] text-text-muted font-mono ml-2">index.html</span>
        </div>

        <!-- Code -->
        <div class="p-5 font-mono text-[13px] leading-[1.9]">
          <div class="flex">
            <span class="w-6 text-right text-text-muted/40 select-none mr-5 shrink-0 text-xs">1</span>
            <span><span class="text-[#f472b6]">&lt;script</span></span>
          </div>
          <div class="flex">
            <span class="w-6 text-right text-text-muted/40 select-none mr-5 shrink-0 text-xs">2</span>
            <span>&nbsp;&nbsp;<span class="text-[#c4b5fd]">src</span>=<span class="text-[#6ee7b7]">"https://cdn.jsdelivr.net/npm/@chatcops/widget"</span></span>
          </div>
          <div class="flex">
            <span class="w-6 text-right text-text-muted/40 select-none mr-5 shrink-0 text-xs">3</span>
            <span>&nbsp;&nbsp;<span class="text-[#c4b5fd]">data-api-url</span>=<span class="text-[#6ee7b7]">"https://your-api.com/chat"</span></span>
          </div>
          <div class="flex">
            <span class="w-6 text-right text-text-muted/40 select-none mr-5 shrink-0 text-xs">4</span>
            <span>&nbsp;&nbsp;<span class="text-[#c4b5fd]">data-accent</span>=<span class="text-[#6ee7b7]">"#6366f1"</span></span>
          </div>
          <div class="flex">
            <span class="w-6 text-right text-text-muted/40 select-none mr-5 shrink-0 text-xs">5</span>
            <span><span class="text-[#f472b6]">&gt;&lt;/script&gt;</span></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="mt-14 flex flex-wrap items-center justify-center gap-x-10 gap-y-4 text-sm text-text-muted" data-animate data-animate-delay="5">
      <span class="flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-[#22d3ee]"></span>
        ~7KB gzipped
      </span>
      <span class="flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-success"></span>
        Zero Dependencies
      </span>
      <span class="flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-primary-light"></span>
        MIT License
      </span>
    </div>
  </div>
</section>
