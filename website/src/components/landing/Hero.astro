<section class="hero section">
  <div class="container">
    <div data-animate="fade">
      <span class="hero-label">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        Open Source
      </span>
    </div>

    <h1 data-animate="slide-up">
      AI Chat Widget for <span class="text-gradient-accent">Any Website</span>
    </h1>

    <p class="hero-subtitle" data-animate="slide-up" data-animate-delay="1">
      Drop-in AI chatbot that connects to Claude, OpenAI, or Gemini.
      One script tag. Zero dependencies. Full control.
    </p>

    <div class="hero-code" data-animate="scale" data-animate-delay="2">
      <div class="hero-code-header">
        <span class="hero-code-dot"></span>
        <span class="hero-code-dot"></span>
        <span class="hero-code-dot"></span>
        <span class="hero-code-title">index.html</span>
      </div>
      <pre><span class="punct">&lt;</span><span class="tag">script</span>
  <span class="attr">src</span><span class="punct">="</span><span class="string">https://cdn.jsdelivr.net/npm/@chatcops/widget</span><span class="punct">"</span>
  <span class="attr">data-api-url</span><span class="punct">="</span><span class="string">https://your-api.com/chat</span><span class="punct">"</span>
  <span class="attr">data-accent</span><span class="punct">="</span><span class="string">#6366f1</span><span class="punct">"</span>
<span class="punct">&gt;&lt;/</span><span class="tag">script</span><span class="punct">&gt;</span></pre>
    </div>

    <div class="hero-ctas" data-animate="slide-up" data-animate-delay="3">
      <a href="/getting-started/quick-start" class="btn btn-primary btn-lg">
        Get Started
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
      </a>
      <a href="https://github.com/codercops/chatcops" class="btn btn-outline btn-lg" target="_blank" rel="noopener">
        <svg viewBox="0 0 16 16" fill="currentColor" style="width:1em;height:1em"><path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        View on GitHub
      </a>
    </div>

    <div class="hero-badges" data-animate="fade" data-animate-delay="4">
      <span class="hero-badge">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5 2a2 2 0 00-2 2v14l3.5-2 3.5 2 3.5-2 3.5 2V4a2 2 0 00-2-2H5zm4.707 3.707a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L8.414 9H10a3 3 0 013 3v1a1 1 0 102 0v-1a5 5 0 00-5-5H8.414l1.293-1.293z" clip-rule="evenodd"/></svg>
        ~7KB gzipped
      </span>
      <span class="hero-badge-divider"></span>
      <span class="hero-badge">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
