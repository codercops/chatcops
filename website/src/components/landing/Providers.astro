---
---
<section class="section">
  <div class="container">
    <div class="section-header" data-animate="fade">
      <span class="section-label">Providers</span>
      <h2 class="section-title">Your AI, Your Choice</h2>
      <p class="section-subtitle">
        Switch providers with one config change. No code rewrites needed.
      </p>
    </div>

    <div class="providers-row" data-animate="slide-up" data-animate-delay="1">
      <div class="provider-pill">
        <svg class="provider-icon" viewBox="0 0 28 28" fill="none">
          <rect width="28" height="28" rx="6" fill="#D97706" opacity="0.15"/>
          <path d="M14 6c-1.5 0-3.2.8-4 2.5C9 10 9.5 12 11 13.5c1 1 1.5 2 1.5 3.5h3c0-1.5.5-2.5 1.5-3.5 1.5-1.5 2-3.5 1-5C17.2 6.8 15.5 6 14 6zM12.5 19h3v1h-3v-1z" fill="#D97706"/>
        </svg>
        <span class="provider-name">Claude</span>
      </div>

      <div class="provider-pill">
        <svg class="provider-icon" viewBox="0 0 28 28" fill="none">
          <rect width="28" height="28" rx="6" fill="#10B981" opacity="0.15"/>
          <circle cx="14" cy="14" r="6" stroke="#10B981" stroke-width="2"/>
          <circle cx="14" cy="14" r="2" fill="#10B981"/>
        </svg>
        <span class="provider-name">OpenAI</span>
      </div>

      <div class="provider-pill">
        <svg class="provider-icon" viewBox="0 0 28 28" fill="none">
          <rect width="28" height="28" rx="6" fill="#3B82F6" opacity="0.15"/>
          <path d="M8 14l3-6 3 6-3 6-3-6zm6 0l3-6 3 6-3 6-3-6z" fill="#3B82F6" opacity="0.6"/>
          <path d="M11 14l3-6 3 6-3 6-3-6z" fill="#3B82F6"/>
        </svg>
        <span class="provider-name">Gemini</span>
      </div>
    </div>
  </div>
</section>
