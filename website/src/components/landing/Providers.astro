---
---
<section class="relative py-28">
  <div class="section-divider"></div>

  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center mb-16" data-animate>
      <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary-glow px-3 py-1 text-xs font-medium text-primary-light mb-5">
        <svg viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3"><path d="M13 7H7v6h6V7z"/><path fill-rule="evenodd" d="M7 2a1 1 0 012 0v1h2V2a1 1 0 112 0v1h2a2 2 0 012 2v2h1a1 1 0 110 2h-1v2h1a1 1 0 110 2h-1v2a2 2 0 01-2 2h-2v1a1 1 0 11-2 0v-1H9v1a1 1 0 11-2 0v-1H5a2 2 0 01-2-2v-2H2a1 1 0 110-2h1V9H2a1 1 0 010-2h1V5a2 2 0 012-2h2V2zM5 5h10v10H5V5z" clip-rule="evenodd"/></svg>
        Providers
      </span>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        Your AI, your <span class="text-gradient">choice</span>
      </h2>
      <p class="mt-4 text-text-secondary max-w-lg mx-auto text-lg">
        Switch providers with one config change. No code rewrites needed.
      </p>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <!-- Claude -->
      <div class="flex items-center gap-4 rounded-2xl border border-border bg-bg-card px-6 py-4 transition-colors hover:border-border-hover" data-animate data-animate-delay="1">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-amber-500/10 text-amber-400">
          <svg viewBox="0 0 24 24" class="w-6 h-6" fill="currentColor">
            <path d="M16.5 3.5c-.2 0-.4.1-.5.2L6.5 14.2c-.3.3-.3.7 0 .9l3.5 3.5c.1.1.3.2.5.2s.4-.1.5-.2L20.5 8.1c.3-.3.3-.7 0-.9L17 3.7c-.1-.1-.3-.2-.5-.2zM3.5 17.5c-.2 0-.4.1-.5.2-.3.3-.3.7 0 .9l3.5 3.5c.3.3.7.3.9 0 .3-.3.3-.7 0-.9L3.9 17.7c-.1-.1-.3-.2-.4-.2z" />
          </svg>
        </div>
        <div>
          <div class="text-[15px] font-semibold text-text">Claude</div>
          <div class="text-xs text-text-muted">Anthropic</div>
        </div>
      </div>

      <!-- OpenAI -->
      <div class="flex items-center gap-4 rounded-2xl border border-border bg-bg-card px-6 py-4 transition-colors hover:border-border-hover" data-animate data-animate-delay="2">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400">
          <svg viewBox="0 0 24 24" class="w-6 h-6" fill="currentColor">
            <path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z" />
          </svg>
        </div>
        <div>
          <div class="text-[15px] font-semibold text-text">OpenAI</div>
          <div class="text-xs text-text-muted">GPT Models</div>
        </div>
      </div>

      <!-- Gemini -->
      <div class="flex items-center gap-4 rounded-2xl border border-border bg-bg-card px-6 py-4 transition-colors hover:border-border-hover" data-animate data-animate-delay="3">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-500/10 text-blue-400">
          <svg viewBox="0 0 24 24" class="w-6 h-6" fill="currentColor">
            <path d="M12 0C5.352 0 0 5.352 0 12s5.352 12 12 12 12-5.352 12-12S18.648 0 12 0zm0 2c5.545 0 10 4.455 10 10s-4.455 10-10 10S2 17.545 2 12 6.455 2 12 2zm-1 4L8 12l3 6 3-6z" />
          </svg>
        </div>
        <div>
          <div class="text-[15px] font-semibold text-text">Gemini</div>
          <div class="text-xs text-text-muted">Google AI</div>
        </div>
      </div>
    </div>
  </div>
</section>
