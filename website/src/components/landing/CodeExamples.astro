---
import CodeTabs from '../react/CodeTabs.tsx';
---

<section class="relative py-28">
  <div class="section-divider"></div>

  <div class="mx-auto max-w-3xl px-6">
    <div class="text-center mb-16" data-animate>
      <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary-glow px-3 py-1 text-xs font-medium text-primary-light mb-5">
        <svg viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3"><path fill-rule="evenodd" d="M2 5a2 2 0 012-2h12a2 2 0 012 2v2a2 2 0 01-2 2H4a2 2 0 01-2-2V5zm14 1a1 1 0 11-2 0 1 1 0 012 0zM2 13a2 2 0 012-2h12a2 2 0 012 2v2a2 2 0 01-2 2H4a2 2 0 01-2-2v-2zm14 1a1 1 0 11-2 0 1 1 0 012 0z" clip-rule="evenodd"/></svg>
        Adapters
      </span>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        Deploy <span class="text-gradient">anywhere</span>
      </h2>
      <p class="mt-4 text-text-secondary max-w-lg mx-auto text-lg">
        First-class adapters for every major platform. Copy, paste, deploy.
      </p>
    </div>

    <div data-animate data-animate-delay="1">
      <CodeTabs client:visible />
    </div>
  </div>
</section>
